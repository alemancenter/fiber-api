# =============================================================================
# Backend Production Environment — api.alemancenter.com
# =============================================================================
# Copy this file to .env and fill in real values before starting the server.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Alemancenter API"
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8081
APP_URL=https://api.alemancenter.com
APP_TIMEZONE=Asia/Amman
APP_LOCALE=ar

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX

# Must match NEXT_PUBLIC_FRONTEND_API_KEY and FRONTEND_API_KEY in the frontend .env
FRONTEND_API_KEY=REPLACE_WITH_STRONG_RANDOM_KEY

# Frontend domain — used by CORS and FrontendGuard
FRONTEND_URL=https://alemancenter.com

# ── CORS (Critical for browser login to work) ────────────────────────────────
# Must match the frontend domain EXACTLY (with https://, no trailing slash)
CORS_ALLOWED_ORIGINS=https://alemancenter.com

# ── Proxy / IP Detection ─────────────────────────────────────────────────────
# Nginx runs on 127.0.0.1 — trust it so Fiber reads X-Forwarded-For correctly
TRUSTED_PROXIES=127.0.0.1

# IP of the Next.js SSR server (same machine = 127.0.0.1)
# Used by FrontendGuard to trust SSR requests without requiring a frontend key
SSR_TRUSTED_IPS=127.0.0.1

# ── Databases ────────────────────────────────────────────────────────────────
DB_HOST_JO=127.0.0.1
DB_PORT_JO=3306
DB_NAME_JO=alemancenter_jo
DB_USER_JO=REPLACE
DB_PASS_JO=REPLACE

DB_HOST_SA=127.0.0.1
DB_PORT_SA=3306
DB_NAME_SA=alemancenter_sa
DB_USER_SA=REPLACE
DB_PASS_SA=REPLACE

DB_HOST_EG=127.0.0.1
DB_PORT_EG=3306
DB_NAME_EG=alemancenter_eg
DB_USER_EG=REPLACE
DB_PASS_EG=REPLACE

DB_HOST_PS=127.0.0.1
DB_PORT_PS=3306
DB_NAME_PS=alemancenter_ps
DB_USER_PS=REPLACE
DB_PASS_PS=REPLACE

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=REPLACE
MAIL_PASSWORD=REPLACE
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@alemancenter.com
MAIL_FROM_NAME="Alemancenter"

# Email verification reminders
EMAIL_VERIFICATION_REMINDER_ENABLED=false
EMAIL_VERIFICATION_REMINDER_INTERVAL_HOURS=24
EMAIL_VERIFICATION_REMINDER_BATCH_LIMIT=100

# ── Bounce Mailbox (IMAP) ─────────────────────────────────────────────────────
MAIL_BOUNCE_ADDRESS=bounce@alemancenter.com
BOUNCE_PROCESSOR_ENABLED=false
BOUNCE_IMAP_HOST=mail.alemancenter.com
BOUNCE_IMAP_PORT=993
BOUNCE_IMAP_TLS=true
BOUNCE_IMAP_USERNAME=bounce@alemancenter.com
BOUNCE_IMAP_PASSWORD=REPLACE

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_DRIVER=local
STORAGE_PATH=/var/www/vhosts/alemancenter.com/httpdocs/storage/app/public
STORAGE_URL=https://api.alemancenter.com/storage

# ── Logs ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=error
LOG_PATH=/var/www/vhosts/alemancenter.com/logs/fiber-api.log
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=5
LOG_MAX_AGE=30
