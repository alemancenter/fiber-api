# Application
APP_NAME="Alemancenter API"
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8080
APP_URL=https://api.alemancenter.com
APP_TIMEZONE=UTC
APP_LOCALE=ar

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_EXPIRE_HOURS=24
JWT_REFRESH_HOURS=168

# Frontend Security
FRONTEND_API_KEY=your_frontend_api_key_here
FRONTEND_URL=https://alemancenter.com
CORS_ALLOWED_ORIGINS=https://alemancenter.com,https://www.alemancenter.com,http://localhost:3000,http://localhost:3001

# Rate Limiting
FRONTEND_RATE_LIMIT=true
FRONTEND_RATE_LIMIT_MAX=100
FRONTEND_RATE_LIMIT_WINDOW=60
LOGIN_RATE_LIMIT=5
API_RATE_LIMIT=60
SSR_RATE_LIMIT_MAX=2000

# SSR Trusted IPs (comma separated)
SSR_TRUSTED_IPS=127.0.0.1,::1

# =====================
# DATABASE - Jordan (Default)
# =====================
DB_HOST_JO=127.0.0.1
DB_PORT_JO=3306
DB_NAME_JO=alhurani_jo
DB_USER_JO=your_db_user
DB_PASS_JO=your_secure_password
DB_CHARSET=utf8mb4

# Database - Saudi Arabia
DB_HOST_SA=127.0.0.1
DB_PORT_SA=3306
DB_NAME_SA=admin_SA_data
DB_USER_SA=your_db_user
DB_PASS_SA=your_secure_password

# Database - Egypt
DB_HOST_EG=127.0.0.1
DB_PORT_EG=3306
DB_NAME_EG=admin_EG_data
DB_USER_EG=your_db_user
DB_PASS_EG=your_secure_password

# Database - Palestine
DB_HOST_PS=127.0.0.1
DB_PORT_PS=3306
DB_NAME_PS=admin_PS_data
DB_USER_PS=your_db_user
DB_PASS_PS=your_secure_password

# Database Pool
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=3600

# =====================
# REDIS
# =====================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_PREFIX=alemancenter

# =====================
# MAIL
# =====================
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_secure_mail_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@alemancenter.com
MAIL_FROM_NAME="Alemancenter"

# =====================
# GOOGLE OAUTH
# =====================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://api.alemancenter.com/api/auth/google/callback

# =====================
# FIREBASE (Optional)
# =====================
FCM_ENABLED=false
FCM_PROJECT_ID=your_firebase_project_id
FCM_SERVICE_ACCOUNT_FILE=/absolute/path/to/firebase-service-account.json

# =====================
# ONESIGNAL (Optional)
# =====================
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# =====================
# AI (Together AI)
# =====================
TOGETHER_AI_API_KEY=

# =====================
# STORAGE
# =====================
STORAGE_DRIVER=local
STORAGE_PATH=./storage/uploads
STORAGE_URL=https://api.alemancenter.com/storage

# =====================
# SECURITY
# =====================
APP_ADD_HSTS=true
SESSION_LIFETIME=30
VISITOR_ACTIVE_MINUTES=5
VISITOR_PRUNE_MINUTES=30

# =====================
# LOGGING
# =====================
LOG_LEVEL=error
LOG_PATH=./storage/logs/app.log
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=5
LOG_MAX_AGE=30

# =====================
# GEOIP
# =====================
GEOIP_DB_PATH=./storage/GeoLite2-City.mmdb
